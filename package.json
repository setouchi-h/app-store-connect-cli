{
  "name": "app-store-connect-cli",
  "version": "0.1.0",
  "description": "App Store Connect analytics CLI",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "bin": {
    "asc": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "jose": "^6.1.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=24"
  }
}
